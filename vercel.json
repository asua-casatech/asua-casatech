{
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/camera", "destination": "/camera/index.html" },
    { "source": "/camera/:path*", "destination": "/camera/:path*" },
    { "source": "/smartwatch", "destination": "/smartwatch/index.html" },
    { "source": "/smartwatch/:path*", "destination": "/smartwatch/:path*" },
    { "source": "/microfone", "destination": "/microfone/index.html" },
    { "source": "/microfone/:path*", "destination": "/microfone/:path*" },
    { "source": "/", "destination": "/index.html" }
  ]
}
