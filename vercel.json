{
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/camera", "dest": "/camera/index.html" },
    { "src": "/camera/(.*)", "dest": "/camera/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}